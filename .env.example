# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Private key of the deployer wallet (without 0x prefix is fine for Foundry).
PRIVATE_KEY=your_private_key_here

# RPC endpoint — Ink Sepolia is pre-configured in foundry.toml.
# Override here if you want a different provider.
RPC_URL=https://rpc-gel-sepolia-ingress.inkonchain.com
